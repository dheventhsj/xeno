{
  "name": "@xenopilot/crm-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run db:generate",
    "db:generate": "prisma generate --schema ../backend/packages/database/prisma/schema.prisma",
    "dev": "next dev -H 0.0.0.0",
    "build": "npm run db:generate && next build && node scripts/copy-prisma-to-next.mjs",
    "start": "next start -H 0.0.0.0",
    "worker": "tsx workers/dispatch-worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@tanstack/react-query": "^5.80.7",
    "@xenopilot/ai-engine": "file:../backend/packages/ai-engine",
    "@xenopilot/analytics": "file:../backend/packages/analytics",
    "@xenopilot/database": "file:../backend/packages/database",
    "@xenopilot/shared": "file:../backend/packages/shared",
    "axios": "^1.17.0",
    "bullmq": "^5.53.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@prisma/nextjs-monorepo-workaround-plugin": "^7.8.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
