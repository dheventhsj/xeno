{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix=../backend && npm install",
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "regions": ["bom1"],
  "env": {
    "DISABLE_REDIS": "1",
    "SIMULATE_CHANNEL": "1"
  },
  "functions": {
    "app/api/**/route.js": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}
