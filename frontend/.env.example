# ─── Production (Vercel) — set in Vercel dashboard ───
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
WEBHOOK_SECRET=change-me-to-random-string
DISABLE_REDIS=1
SIMULATE_CHANNEL=1
SEED_SECRET=change-me-to-random-string
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: external channel service (Railway/Render). Leave empty to use built-in simulator.
# CHANNEL_SERVICE_URL=
