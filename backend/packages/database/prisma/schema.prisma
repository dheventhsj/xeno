generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  output        = "../../../../frontend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  phone             String?
  city              String?
  preferredCategory String   @map("preferred_category")
  preferredChannel  String   @map("preferred_channel")
  totalSpend        Float    @default(0) @map("total_spend")
  orderCount        Int      @default(0) @map("order_count")
  lastOrderDate     DateTime? @map("last_order_date")
  churnScore        Float    @default(0) @map("churn_score")
  ltvScore          Float    @default(0) @map("ltv_score")
  engagementScore   Float    @default(0) @map("engagement_score")
  purchaseProb      Float    @default(0) @map("purchase_prob")
  avgOrderValue     Float    @default(0) @map("avg_order_value")
  daysSinceOrder    Int      @default(0) @map("days_since_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orders          Order[]
  communications  Communication[]
  timeline        CustomerTimeline[]

  @@index([totalSpend])
  @@index([lastOrderDate])
  @@index([churnScore])
  @@index([ltvScore])
  @@index([preferredCategory])
  @@index([city])
  @@index([engagementScore])
  @@index([purchaseProb])
  @@map("customers")
}

model Order {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  amount     Float
  category   String
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([category])
  @@map("orders")
}

model Segment {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  aiReasoning        String   @default("[]") @map("ai_reasoning")
  segmentDefinition  String   @map("segment_definition")
  customerCount      Int      @default(0) @map("customer_count")
  revenuePotential   Float    @default(0) @map("revenue_potential")
  churnRisk          Float    @default(0) @map("churn_risk")
  demographics       String?  @map("demographics")
  createdAt          DateTime @default(now()) @map("created_at")

  campaigns Campaign[]

  @@map("segments")
}

model Campaign {
  id                     String         @id @default(cuid())
  goal                   String
  segmentId              String?        @map("segment_id")
  recommendedChannel     String         @map("recommended_channel")
  messageVariantA        String         @map("message_variant_a")
  messageVariantB        String         @map("message_variant_b")
  messageVariantC        String         @map("message_variant_c")
  expectedOpenRate       Float          @map("expected_open_rate")
  expectedClickRate      Float          @map("expected_click_rate")
  expectedConversionRate Float          @map("expected_conversion_rate")
  expectedRevenue        Float          @map("expected_revenue")
  status                 String         @default("DRAFT")
  scheduledAt            DateTime?      @map("scheduled_at")
  launchedAt             DateTime?      @map("launched_at")
  completedAt            DateTime?      @map("completed_at")
  totalRecipients        Int            @default(0) @map("total_recipients")
  aiReasoning            String?        @map("ai_reasoning")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  segment         Segment?         @relation(fields: [segmentId], references: [id])
  communications  Communication[]
  analytics       CampaignAnalytics?

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model CampaignAnalytics {
  id           String   @id @default(cuid())
  campaignId   String   @unique @map("campaign_id")
  sent         Int      @default(0)
  delivered    Int      @default(0)
  failed       Int      @default(0)
  opened       Int      @default(0)
  read         Int      @default(0)
  clicked      Int      @default(0)
  converted    Int      @default(0)
  revenue      Float    @default(0)
  lastEventAt  DateTime? @map("last_event_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_analytics")
}

model Communication {
  id              String              @id @default(cuid())
  campaignId      String              @map("campaign_id")
  customerId      String              @map("customer_id")
  channel         String
  message         String
  variant         String              @default("A")
  status          String              @default("QUEUED")
  sentAt          DateTime?           @map("sent_at")
  fallbackChannel String?             @map("fallback_channel")
  fallbackAt      DateTime?           @map("fallback_at")
  isFallback      Int                 @default(0) @map("is_fallback")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  campaign Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events   CommunicationEvent[]

  @@unique([campaignId, customerId])
  @@index([campaignId, status])
  @@map("communications")
}

model CommunicationEvent {
  id              String    @id @default(cuid())
  communicationId String    @map("communication_id")
  eventType       String    @map("event_type")
  eventId         String    @map("event_id")
  timestamp       DateTime
  meta            String?

  communication Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@unique([communicationId, eventType, eventId])
  @@index([communicationId])
  @@map("communication_events")
}

model CustomerTimeline {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  eventType  String   @map("event_type")
  title      String
  detail     String?
  meta       String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("customer_timeline")
}

model AgentSession {
  id        String   @id @default(cuid())
  messages  String   @default("[]")
  context   String   @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agent_sessions")
}

model AuditLog {
  id           String   @id @default(cuid())
  aggregateId  String   @map("aggregate_id")
  aggregateType String  @map("aggregate_type")
  eventType    String   @map("event_type")
  payload      String
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([aggregateId, version])
  @@index([aggregateType, createdAt])
  @@map("audit_log")
}

model MarketingMemory {
  id         String   @id @default(cuid())
  insight    String
  channel    String?
  segment    String?
  metric     String?
  value      Float?
  confidence Float    @default(0.8)
  campaignId String?  @map("campaign_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([channel])
  @@index([segment])
  @@map("marketing_memory")
}

model AgentReasoningLog {
  id        String   @id @default(cuid())
  sessionId String?  @map("session_id")
  goal      String
  steps     String
  tools     String   @default("[]")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("agent_reasoning_logs")
}
